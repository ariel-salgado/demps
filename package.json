		"@codemirror/view": "^6.22.3",
		"@geoman-io/leaflet-geoman-free": "^2.15.0",
		"@sveltejs/adapter-auto": "^3.0.1",
		"@sveltejs/kit": "^2.0.6",
		"@sveltejs/vite-plugin-svelte": "^3.0.1",
