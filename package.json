		"eslint-plugin-svelte": "2.36.0-next.3",
		"husky": "^8.0.3",
		"leaflet": "^1.9.4",
		"lint-staged": "^15.2.0",
		"postcss": "^8.4.32",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.1.2",
		"prettier-plugin-tailwindcss": "^0.5.9",
		"svelte": "5.0.0-next.26",
		"svelte-check": "^3.6.2",
		"svelte-eslint-parser": "0.34.0-next.6",
		"tailwind-merge": "^2.2.0",
